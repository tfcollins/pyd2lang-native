# SW Light Theme — Software/AI diagram styles
# ADI (analog.com) brand colors applied to software architecture diagrams

vars: {
  sw-blue: "#0067B9"
  sw-dark-blue: "#004A87"
  sw-light-blue: "#4D9AD5"
  sw-pale-blue: "#D6EAF8"
  sw-bg-cream: "#FDF6EC"
  sw-bg-blue: "#E8F4FD"
  sw-black: "#231F20"
  sw-grey: "#58595B"
  sw-light-grey: "#D1D3D4"
  sw-white: "#FFFFFF"
  sw-red: "#C8102E"
  sw-green: "#007A33"
  sw-amber: "#F5A623"
}

classes: {
  # ── Containers ──
  sw-container: {
    style: {
      fill: "#E8F4FD"
      stroke: "#0067B9"
      stroke-width: 2
      border-radius: 12
      font-color: "#231F20"
      font-size: 16
    }
  }
  sw-container-cream: {
    style: {
      fill: "#FDF6EC"
      stroke: "#D1D3D4"
      stroke-width: 1
      border-radius: 12
      font-color: "#231F20"
      font-size: 16
    }
  }
  sw-container-green: {
    style: {
      fill: "#E8F5E9"
      stroke: "#007A33"
      stroke-width: 2
      border-radius: 12
      font-color: "#231F20"
      font-size: 16
    }
  }
  sw-container-amber: {
    style: {
      fill: "#FFF3E0"
      stroke: "#F5A623"
      stroke-width: 2
      border-radius: 12
      font-color: "#231F20"
      font-size: 16
    }
  }
  sw-container-red: {
    style: {
      fill: "#FFEBEE"
      stroke: "#C8102E"
      stroke-width: 2
      border-radius: 12
      font-color: "#231F20"
      font-size: 16
    }
  }
  sw-container-white: {
    style: {
      fill: "#FFFFFF"
      stroke: "#D1D3D4"
      stroke-width: 1
      border-radius: 12
      font-color: "#231F20"
      font-size: 16
    }
  }

  # ── Step highlights ──
  sw-step-blue: {
    style: {
      fill: "#D6EAF8"
      stroke: "#0067B9"
      stroke-width: 1
      border-radius: 8
      font-color: "#231F20"
      font-size: 14
    }
  }
  sw-step-green: {
    style: {
      fill: "#E8F5E9"
      stroke: "#007A33"
      stroke-width: 1
      border-radius: 8
      font-color: "#231F20"
      font-size: 14
    }
  }
  sw-step-amber: {
    style: {
      fill: "#FFF3E0"
      stroke: "#F5A623"
      stroke-width: 1
      border-radius: 8
      font-color: "#231F20"
      font-size: 14
    }
  }
  sw-step-white: {
    style: {
      fill: "#FFFFFF"
      stroke: "#D1D3D4"
      stroke-width: 1
      border-radius: 8
      font-color: "#231F20"
      font-size: 14
    }
  }

  # ── Typography ──
  sw-title: {
    shape: text
    style: {
      font-size: 22
      font-color: "#0067B9"
      bold: true
    }
  }
  sw-subtitle: {
    shape: text
    style: {
      font-size: 16
      font-color: "#231F20"
      bold: true
    }
  }
  sw-note: {
    shape: page
    style: {
      fill: "#FFFDE7"
      stroke: "#D1D3D4"
      stroke-width: 1
      font-size: 11
      font-color: "#58595B"
      italic: true
    }
  }

  # ── Connection/flow styles ──
  sw-flow: {
    style: {
      stroke: "#0067B9"
      stroke-width: 2
      font-color: "#231F20"
      font-size: 13
    }
  }
  sw-flow-data: {
    style: {
      stroke: "#004A87"
      stroke-width: 3
      font-color: "#004A87"
      font-size: 13
    }
  }
  sw-flow-control: {
    style: {
      stroke: "#58595B"
      stroke-width: 2
      stroke-dash: 5
      font-color: "#58595B"
      font-size: 13
    }
  }
  sw-flow-async: {
    style: {
      stroke: "#F5A623"
      stroke-width: 2
      stroke-dash: 3
      font-color: "#F5A623"
      font-size: 13
    }
  }
  sw-flow-error: {
    style: {
      stroke: "#C8102E"
      stroke-width: 2
      font-color: "#C8102E"
      font-size: 13
    }
  }
  sw-flow-success: {
    style: {
      stroke: "#007A33"
      stroke-width: 2
      font-color: "#007A33"
      font-size: 13
    }
  }
  sw-flow-feedback: {
    style: {
      stroke: "#4D9AD5"
      stroke-width: 2
      stroke-dash: 3
      font-color: "#4D9AD5"
      font-size: 13
    }
  }
  sw-flow-light: {
    style: {
      stroke: "#D1D3D4"
      stroke-width: 2
      font-color: "#58595B"
      font-size: 12
    }
  }
}
