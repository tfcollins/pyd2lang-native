# SW component classes — styled shapes with type-specific colors
# Color coding: blue=compute, green=output/eval, amber=config/data, grey=tools, dark=terminal

classes: {
  # ── Core Software / Infrastructure ──
  sw-server: {
    style.fill: "#E3F2FD"
    style.stroke: "#0067B9"
    style.border-radius: 8
    style.shadow: true
    style.font-color: "#231F20"
  }
  sw-database: {
    shape: cylinder
    style.fill: "#E8EAF6"
    style.stroke: "#004A87"
    style.font-color: "#231F20"
  }
  sw-queue: {
    style.fill: "#E3F2FD"
    style.stroke: "#0067B9"
    style.border-radius: 8
    style.shadow: true
