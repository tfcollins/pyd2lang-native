# ADI DataX overview dark theme.

classes: {
  datax-panel: {
    style.fill: "#1A2028"
    style.stroke: "#3A424B"
    style.stroke-width: 1
    style.border-radius: 14
    style.font-color: "#E5E5E5"
  }
  datax-band: {
    style.fill: "#1F2A3D"
    style.stroke: "#3A4960"
    style.stroke-width: 1
    style.border-radius: 10
    style.font-color: "#92AACB"
  }
  datax-title: {
    shape: text
    style.font-size: 22
    style.font-color: "#E5E5E5"
    style.bold: true
  }
  datax-subtitle: {
    shape: text
    style.font-size: 14
    style.font-color: "#AAAAAA"
  }
  datax-panel-label: {
    shape: text
    style.font-size: 15
    style.font-color: "#AAAAAA"
    style.bold: true
  }
  datax-panel-sublabel: {
    shape: text
    style.font-size: 12
    style.font-color: "#AAAAAA"
  }
  datax-section-label: {
    shape: text
    style.font-size: 12
    style.font-color: "#AAAAAA"
    style.bold: true
  }
  datax-layer-label: {
    shape: text
    style.font-size: 12
    style.font-color: "#AAAAAA"
    style.bold: true
  }
  datax-label: {
    shape: text
    style.font-size: 13
    style.font-color: "#CCCCCC"
    style.bold: true
  }
  datax-note: {
    shape: text
    style.font-size: 12
    style.font-color: "#AAAAAA"
    style.italic: true
  }
  datax-flow: {
    style.stroke: "#5A6470"
    style.stroke-width: 2
    style.font-color: "#AAAAAA"
    style.font-size: 12
    style.italic: true
  }
  datax-flow-accent: {
    style.stroke: "#7DA3C4"
    style.stroke-width: 2
    style.font-color: "#7DA3C4"
    style.font-size: 12
    style.italic: true
  }
  datax-flow-muted: {
    style.stroke: "#3A424B"
    style.stroke-width: 1
    style.font-color: "#AAAAAA"
    style.font-size: 12
    style.italic: true
  }
  datax-flow-dashed: {
    style.stroke: "#5A6470"
    style.stroke-width: 2
    style.stroke-dash: 5
    style.font-color: "#AAAAAA"
    style.font-size: 12
    style.italic: true
  }
  datax-flow-good: {
    style.stroke: "#7AA886"
    style.stroke-width: 2
    style.font-color: "#7AA886"
    style.font-size: 12
    style.italic: true
  }
  datax-flow-warn: {
    style.stroke: "#C79A9A"
    style.stroke-width: 2
    style.font-color: "#C79A9A"
    style.font-size: 12
    style.italic: true
  }

  datax-box: {
    style.fill: "#1F242C"
    style.stroke: "#3A424B"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#E5E5E5"
  }
  datax-hardware: {
    style.fill: "#4A3328"
    style.stroke: "#3A424B"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#E5E5E5"
  }
  datax-hardware-alt: {
    style.fill: "#3A4530"
    style.stroke: "#3A424B"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#E5E5E5"
  }
  datax-processor: {
    style.fill: "#4A3D20"
    style.stroke: "#3A424B"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#E5E5E5"
  }
  datax-hdl: {
    style.fill: "#2C4A39"
    style.stroke: "#3A424B"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#E5E5E5"
  }
  datax-driver: {
    style.fill: "#2A4060"
    style.stroke: "#3A424B"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#E5E5E5"
  }
  datax-application: {
    style.fill: "#3A2C4A"
    style.stroke: "#3A424B"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#E5E5E5"
  }
  datax-application-alt: {
    style.fill: "#5A3030"
    style.stroke: "#3A424B"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#E5E5E5"
  }
  datax-info: {
    style.fill: "#2A3848"
    style.stroke: "#3A424B"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#E5E5E5"
  }
  datax-note-box: {
    style.fill: "#4A3D1A"
    style.stroke: "#3A424B"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#E5E5E5"
  }
  datax-note-warm: {
    style.fill: "#4A3520"
    style.stroke: "#3A424B"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#E5E5E5"
  }
  datax-good: {
    style.fill: "#2A3E2C"
    style.stroke: "#3A424B"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#E5E5E5"
  }
  datax-warn: {
    style.fill: "#3E2A2A"
    style.stroke: "#3A424B"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#E5E5E5"
  }
  datax-muted: {
    style.fill: "#2A2E35"
    style.stroke: "#3A424B"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#E5E5E5"
  }
  datax-blank: {
    style.fill: "#1F242C"
    style.stroke: "#3A424B"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#E5E5E5"
  }
}
