# ADI DataX overview light theme.

classes: {
  datax-panel: {
    style.fill: "#F7F1E6"
    style.stroke: "#E3DCC9"
    style.stroke-width: 1
    style.border-radius: 14
    style.font-color: "#2B2A26"
  }
  datax-band: {
    style.fill: "#E4ECF6"
    style.stroke: "#B6C4DC"
    style.stroke-width: 1
    style.border-radius: 10
    style.font-color: "#4A6A92"
  }
  datax-title: {
    shape: text
    style.font-size: 22
    style.font-color: "#2B2A26"
    style.bold: true
  }
  datax-subtitle: {
    shape: text
    style.font-size: 14
    style.font-color: "#6B6660"
  }
  datax-panel-label: {
    shape: text
    style.font-size: 15
    style.font-color: "#6B6660"
    style.bold: true
  }
  datax-panel-sublabel: {
    shape: text
    style.font-size: 12
    style.font-color: "#6B6660"
  }
  datax-section-label: {
    shape: text
    style.font-size: 12
    style.font-color: "#6B6660"
    style.bold: true
  }
  datax-layer-label: {
    shape: text
    style.font-size: 12
    style.font-color: "#6B6660"
    style.bold: true
  }
  datax-label: {
    shape: text
    style.font-size: 13
    style.font-color: "#4A463F"
    style.bold: true
  }
  datax-note: {
    shape: text
    style.font-size: 12
    style.font-color: "#6B6660"
    style.italic: true
  }
  datax-flow: {
    style.stroke: "#B3AA97"
    style.stroke-width: 2
    style.font-color: "#6B6660"
    style.font-size: 12
    style.italic: true
  }
  datax-flow-accent: {
    style.stroke: "#6B8AAA"
    style.stroke-width: 2
    style.font-color: "#6B8AAA"
    style.font-size: 12
    style.italic: true
  }
  datax-flow-muted: {
    style.stroke: "#D1D3D4"
    style.stroke-width: 1
    style.font-color: "#6B6660"
    style.font-size: 12
    style.italic: true
  }
  datax-flow-dashed: {
    style.stroke: "#B3AA97"
    style.stroke-width: 2
    style.stroke-dash: 5
    style.font-color: "#6B6660"
    style.font-size: 12
    style.italic: true
  }
  datax-flow-good: {
    style.stroke: "#5E8B6B"
    style.stroke-width: 2
    style.font-color: "#5E8B6B"
    style.font-size: 12
    style.italic: true
  }
  datax-flow-warn: {
    style.stroke: "#B08585"
    style.stroke-width: 2
    style.font-color: "#B08585"
    style.font-size: 12
    style.italic: true
  }
}
