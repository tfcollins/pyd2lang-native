# ADI DataX overview components.
# These classes mirror the semantic fills used by the SVG figures in
# doc-adi/docs/overview: hardware, processors, HDL/firmware, drivers,
# libraries, applications, and callout boxes.

classes: {
  datax-box: {
    style.fill: "#FFFFFF"
    style.stroke: "#C9BFA9"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#2B2A26"
  }
  datax-hardware: {
    style.fill: "#F7C8A4"
    style.stroke: "#C9BFA9"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#2B2A26"
  }
  datax-hardware-alt: {
    style.fill: "#D3E0BD"
    style.stroke: "#C9BFA9"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#2B2A26"
  }
  datax-processor: {
    style.fill: "#F4DCA0"
    style.stroke: "#C9BFA9"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#2B2A26"
  }
  datax-hdl: {
    style.fill: "#B6DAC5"
    style.stroke: "#C9BFA9"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#2B2A26"
  }
  datax-driver: {
    style.fill: "#CBD9E8"
    style.stroke: "#C9BFA9"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#2B2A26"
  }
  datax-application: {
    style.fill: "#E0D0E8"
    style.stroke: "#C9BFA9"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#2B2A26"
  }
  datax-application-alt: {
    style.fill: "#F3C9C9"
    style.stroke: "#C9BFA9"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#2B2A26"
  }
  datax-info: {
    style.fill: "#D4E1EC"
    style.stroke: "#C9BFA9"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#2B2A26"
  }
  datax-note-box: {
    style.fill: "#FAE9C5"
    style.stroke: "#C9BFA9"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#2B2A26"
  }
  datax-note-warm: {
    style.fill: "#F5DEC0"
    style.stroke: "#C9BFA9"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#2B2A26"
  }
  datax-good: {
    style.fill: "#D7E6CF"
    style.stroke: "#C9BFA9"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#2B2A26"
  }
  datax-warn: {
    style.fill: "#ECD2D2"
    style.stroke: "#C9BFA9"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#2B2A26"
  }
  datax-muted: {
    style.fill: "#ECE7DC"
    style.stroke: "#C9BFA9"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#2B2A26"
  }
  datax-blank: {
    style.fill: "#FFFFFF"
    style.stroke: "#C9BFA9"
    style.stroke-width: 1
    style.border-radius: 8
    style.font-color: "#2B2A26"
  }
}
