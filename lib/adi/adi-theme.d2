# ADI Light Theme — Analog Devices, Inc. brand colors
# Based on analog.com brand guidelines

vars: {
  adi-blue: "#0067B9"
  adi-dark-blue: "#004A87"
  adi-light-blue: "#4D9AD5"
  adi-pale-blue: "#A8D4F0"
  adi-bg-blue: "#E8F4FD"
  adi-black: "#212836"
  adi-grey: "#555555"
  adi-light-grey: "#D1D3D4"
  adi-white: "#FFFFFF"
  adi-red: "#C8102E"
  adi-green: "#007A33"
}

classes: {
  adi-container: {
    style: {
      fill: "#E8F4FD"
      stroke: "#0067B9"
      stroke-width: 2
      border-radius: 8
      shadow: true
      font-color: "#212836"
      font-size: 16
    }
  }
  adi-signal: {
    style: {
      stroke: "#0067B9"
      stroke-width: 2
      font-color: "#212836"
      font-size: 13
    }
  }
  adi-signal-analog: {
    style: {
      stroke: "#212836"
      stroke-width: 2
      font-color: "#212836"
      font-size: 13
    }
  }
  adi-signal-digital: {
    style: {
      stroke: "#0067B9"
      stroke-width: 2
      stroke-dash: 5
      font-color: "#0067B9"
      font-size: 13
    }
  }
  adi-signal-clock: {
    style: {
      stroke: "#007A33"
      stroke-width: 1
      stroke-dash: 3
      font-color: "#007A33"
      font-size: 11
    }
  }
  adi-signal-power: {
    style: {
      stroke: "#C8102E"
      stroke-width: 2
      font-color: "#C8102E"
      font-size: 13
    }
  }
  adi-title: {
    shape: text
    style: {
      font-size: 24
      font-color: "#0067B9"
      bold: true
    }
  }
  adi-note: {
    shape: page
    style: {
      fill: "#FFFDE7"
      stroke: "#D1D3D4"
      stroke-width: 1
      font-size: 11
      font-color: "#555555"
      italic: true
    }
  }
}
