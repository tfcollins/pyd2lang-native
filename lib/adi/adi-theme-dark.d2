# ADI Dark Theme — Analog Devices, Inc. brand colors (dark variant)
# Harmonized with adi_doctools "cosmic" Sphinx theme dark mode

vars: {
  adi-blue: "#92befc"
  adi-dark-blue: "#5a9fd4"
  adi-light-blue: "#b8d4f0"
  adi-pale-blue: "#1a2d40"
  adi-bg-blue: "#152535"
  adi-black: "#e5e5e5"
  adi-grey: "#cccccc"
  adi-light-grey: "#3a424b"
  adi-white: "#1e2830"
  adi-red: "#FF6B6B"
  adi-green: "#66BB6A"
}

classes: {
  adi-container: {
    style: {
      fill: "#152535"
      stroke: "#92befc"
      stroke-width: 2
      border-radius: 8
      shadow: true
      font-color: "#e5e5e5"
      font-size: 16
    }
  }
  adi-signal: {
    style: {
      stroke: "#92befc"
      stroke-width: 2
      font-color: "#e5e5e5"
      font-size: 13
    }
  }
  adi-signal-analog: {
    style: {
      stroke: "#e5e5e5"
      stroke-width: 2
      font-color: "#e5e5e5"
      font-size: 13
    }
  }
  adi-signal-digital: {
    style: {
      stroke: "#92befc"
      stroke-width: 2
      stroke-dash: 5
      font-color: "#92befc"
      font-size: 13
    }
  }
  adi-signal-clock: {
    style: {
      stroke: "#66BB6A"
      stroke-width: 1
      stroke-dash: 3
      font-color: "#66BB6A"
      font-size: 11
    }
  }
  adi-signal-power: {
    style: {
      stroke: "#FF6B6B"
      stroke-width: 2
      font-color: "#FF6B6B"
      font-size: 13
    }
  }
  adi-title: {
    shape: text
    style: {
      font-size: 24
      font-color: "#92befc"
      bold: true
    }
  }
  adi-note: {
    shape: page
    style: {
      fill: "#293038"
      stroke: "#3a424b"
      stroke-width: 1
      font-size: 11
      font-color: "#cccccc"
      italic: true
    }
  }
}
