# JIF Light Theme — system clocking and JESD hardware diagrams
# Pale technical canvas mirroring the dark semantic hardware palette.

classes: {
  # ── System-level containers and typography ──
  jif-container: {
    style.fill: "#F8FAFC"
    style.stroke: "#CBD5E1"
    style.stroke-width: 1
    style.border-radius: 14
    style.shadow: true
    style.font-color: "#0F172A"
    style.font-size: 16
  }
  jif-container-clock: {
    style.fill: "#FFF7E6"
    style.stroke: "#C47A00"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-color: "#0F172A"
    style.font-size: 16
  }
  jif-container-converter: {
    style.fill: "#E9F8F1"
    style.stroke: "#07855B"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-color: "#0F172A"
    style.font-size: 16
  }
  jif-container-fpga: {
    style.fill: "#EAF6FB"
    style.stroke: "#087EA4"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-color: "#0F172A"
    style.font-size: 16
  }
  jif-title: {
    shape: text
    style.font-size: 22
    style.font-color: "#0F172A"
    style.bold: true
  }
  jif-subtitle: {
    shape: text
    style.font-size: 13
    style.font-color: "#64748B"
  }
  jif-label: {
    shape: text
    style.font-size: 12
    style.font-color: "#334155"
    style.bold: true
  }
  jif-badge: {
    style.fill: "#EEF2F7"
    style.stroke: "#94A3B8"
    style.stroke-width: 1
    style.border-radius: 20
    style.font-color: "#0F172A"
    style.font-size: 11
  }

  # ── Semantic connection styles ──
  jif-signal: {
    style.stroke: "#64748B"
    style.stroke-width: 2
    style.font-color: "#334155"
    style.font-size: 12
  }
  jif-signal-reference: {
    style.stroke: "#6D4CC2"
    style.stroke-width: 2
    style.font-color: "#5B3FA5"
    style.font-size: 12
  }
  jif-signal-clock: {
    style.stroke: "#C47A00"
    style.stroke-width: 2
    style.font-color: "#9A5A00"
    style.font-size: 12
  }
  jif-signal-sysref: {
    style.stroke: "#B423C8"
    style.stroke-width: 2
    style.stroke-dash: 6
    style.font-color: "#8F1DA1"
    style.font-size: 12
  }
  jif-signal-data: {
    style.stroke: "#087EA4"
    style.stroke-width: 4
    style.font-color: "#036A91"
    style.font-size: 12
  }
  jif-signal-feedback: {
    style.stroke: "#94A3B8"
    style.stroke-width: 1
    style.stroke-dash: 4
    style.font-color: "#64748B"
    style.font-size: 11
  }

  # ── Converter and JESD datapath ──
  adc: {
    icon: "data:image/svg+xml;base64,"
    style.fill: "#E9F8F1"
    style.stroke: "#07855B"
    style.font-color: "#0F172A"
  }
  dac: {
    icon: "data:image/svg+xml;base64,"
    style.fill: "#E9F8F1"
    style.stroke: "#07855B"
    style.font-color: "#0F172A"
  }
  ddc: {
    style.fill: "#E9F8F1"
    style.stroke: "#07855B"
    style.font-color: "#0F172A"
    style.border-radius: 8
  }
  duc: {
    style.fill: "#E9F8F1"
    style.stroke: "#07855B"
    style.font-color: "#0F172A"
    style.border-radius: 8
  }
  jesd204framer: {
    style.fill: "#DFF3FA"
    style.stroke: "#087EA4"
    style.font-color: "#0F172A"
    style.border-radius: 8
  }
  jesd204deframer: {
    style.fill: "#DFF3FA"
    style.stroke: "#087EA4"
    style.font-color: "#0F172A"
    style.border-radius: 8
  }
  framer: {
    style.fill: "#DFF3FA"
    style.stroke: "#087EA4"
    style.font-color: "#0F172A"
    style.border-radius: 8
  }
  deframer: {
    style.fill: "#DFF3FA"
    style.stroke: "#087EA4"
    style.font-color: "#0F172A"
    style.border-radius: 8
  }
  crossbar: {
    icon: "data:image/svg+xml;base64,"
    style.fill: "#FFF7E6"
    style.stroke: "#C47A00"
    style.font-color: "#0F172A"
  }
  mux: {
    icon: "data:image/svg+xml;base64,"
    style.fill: "#FFF7E6"
    style.stroke: "#C47A00"
    style.font-color: "#0F172A"
  }

  # ── Reference and generic structural blocks ──
  input: {
    style.fill: "#F2EDFF"
    style.stroke: "#6D4CC2"
    style.font-color: "#0F172A"
  }
  out_clock_connected: {
    style.fill: "#F2EDFF"
    style.stroke: "#6D4CC2"
    style.font-color: "#0F172A"
  }
  shell: {
    style.fill: "#F3F6FA"
    style.stroke: "#94A3B8"
    style.font-color: "#0F172A"
    style.border-radius: 10
  }

  # ── Clock and PLL blocks ──
  divider: {
    style.fill: "#FFF7E6"
    style.stroke: "#C47A00"
    style.font-color: "#0F172A"
  }
  cpll: {
    style.fill: "#FFF7E6"
    style.stroke: "#C47A00"
    style.font-color: "#0F172A"
    style.border-radius: 10
  }
  qpll: {
    style.fill: "#FFF7E6"
    style.stroke: "#C47A00"
    style.font-color: "#0F172A"
    style.border-radius: 10
  }
  phase-frequency-detector: {
    style.fill: "#FFF7E6"
    style.stroke: "#C47A00"
    style.font-color: "#0F172A"
  }
  charge-pump: {
    style.fill: "#FFF7E6"
    style.stroke: "#C47A00"
    style.font-color: "#0F172A"
    style.border-radius: 8
  }
  loop-filter: {
    style.fill: "#FFF7E6"
    style.stroke: "#C47A00"
    style.font-color: "#0F172A"
    style.border-radius: 8
  }
  vco: {
    style.fill: "#FFF7E6"
    style.stroke: "#C47A00"
    style.font-color: "#0F172A"
  }
  voltage-controlled-oscillator: {
    style.fill: "#FFF7E6"
    style.stroke: "#C47A00"
    style.font-color: "#0F172A"
  }

  # ── FPGA and transceiver blocks ──
  ip: {
    style.fill: "#EAF6FB"
    style.stroke: "#087EA4"
    style.font-color: "#0F172A"
    style.border-radius: 8
  }
  phy: {
    style.fill: "#EAF6FB"
    style.stroke: "#087EA4"
    style.font-color: "#0F172A"
    style.border-radius: 10
  }
  transceiver: {
    style.fill: "#EAF6FB"
    style.stroke: "#087EA4"
    style.font-color: "#0F172A"
    style.border-radius: 8
  }
  serdes: {
    style.fill: "#EAF6FB"
    style.stroke: "#087EA4"
    style.font-color: "#0F172A"
    style.border-radius: 8
  }
  decoder: {
    style.fill: "#EAF6FB"
    style.stroke: "#087EA4"
    style.font-color: "#0F172A"
    style.border-radius: 8
  }
  trx-dividers: {
    style.fill: "#F3F6FA"
    style.stroke: "#94A3B8"
    style.font-color: "#0F172A"
    style.border-radius: 10
  }
  cdr: {
    style.fill: "#EAF6FB"
    style.stroke: "#087EA4"
    style.font-color: "#0F172A"
    style.border-radius: 8
  }
}
