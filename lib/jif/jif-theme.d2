# JIF Light Theme — readable hardware topology and clocking diagrams
# Semantic palette mirrors the dark theme with accessible light surfaces.

classes: {
  jif-container: {
    style.fill: "#F8FAFC"
    style.stroke: "#CBD5E1"
    style.stroke-width: 1
    style.border-radius: 12
    style.shadow: true
    style.font-color: "#0F172A"
    style.font-size: 16
  }
  jif-container-clock: {
    style.fill: "#FFFBEB"
    style.stroke: "#D97706"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-color: "#0F172A"
    style.font-size: 16
  }
  jif-container-converter: {
    style.fill: "#ECFDF5"
    style.stroke: "#059669"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-color: "#0F172A"
    style.font-size: 16
  }
  jif-container-fpga: {
    style.fill: "#ECFEFF"
    style.stroke: "#0891B2"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-color: "#0F172A"
    style.font-size: 16
  }
  jif-title: {
    shape: text
    style.font-size: 22
    style.font-color: "#0F172A"
    style.bold: true
  }
  jif-subtitle: {
    shape: text
    style.font-size: 13
    style.font-color: "#64748B"
  }
  jif-label: {
    shape: text
    style.font-size: 12
    style.font-color: "#334155"
    style.bold: true
  }
  jif-badge: {
    style.fill: "#F1F5F9"
    style.stroke: "#94A3B8"
    style.stroke-width: 1
    style.border-radius: 20
    style.font-color: "#0F172A"
    style.font-size: 11
  }
  jif-signal: {
    style.stroke: "#64748B"
    style.stroke-width: 2
    style.font-color: "#334155"
    style.font-size: 12
  }
  jif-signal-reference: {
    style.stroke: "#7C3AED"
    style.stroke-width: 2
    style.font-color: "#6D28D9"
    style.font-size: 12
  }
  jif-signal-clock: {
    style.stroke: "#D97706"
    style.stroke-width: 2
    style.font-color: "#B45309"
    style.font-size: 12
  }
  jif-signal-sysref: {
    style.stroke: "#C026D3"
    style.stroke-width: 2
    style.stroke-dash: 6
    style.font-color: "#A21CAF"
    style.font-size: 12
  }
  jif-signal-data: {
    style.stroke: "#0284C7"
    style.stroke-width: 4
    style.font-color: "#0369A1"
    style.font-size: 12
  }
  jif-signal-feedback: {
    style.stroke: "#94A3B8"
    style.stroke-width: 1
    style.stroke-dash: 4
    style.font-color: "#64748B"
    style.font-size: 11
  }
}
