# JIF Light Theme

classes: {
  jif-container: {
    style.fill: "#F7F3EA"
    style.stroke: "#DED8CC"
    style.stroke-width: 1
    style.border-radius: 12
    style.shadow: true
    style.font-color: "#1F1E1A"
    style.font-size: 16
  }
  jif-signal: {
    style.stroke: "#5D6675"
    style.stroke-width: 2
    style.font-color: "#5D6675"
    style.font-size: 13
  }
}
