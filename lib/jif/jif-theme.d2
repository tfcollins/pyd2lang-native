# JIF Light Theme

classes: {
  jif-container: {
    style.fill: "#F7F8FE"
    style.stroke: "#0067B9"
    style.stroke-width: 2
    style.border-radius: 8
    style.shadow: true
    style.font-color: "#212836"
    style.font-size: 16
  }
  jif-signal: {
    style.stroke: "#0067B9"
    style.stroke-width: 2
    style.font-color: "#212836"
    style.font-size: 13
  }
}
