# JIF Dark Theme — system clocking and JESD hardware diagrams
# Navy technical canvas with semantic clock, SYSREF, data, and reference colors.

classes: {
  # ── System-level containers and typography ──
  jif-container: {
    style.fill: "#07111F"
    style.stroke: "#26364C"
    style.stroke-width: 1
    style.border-radius: 14
    style.shadow: true
    style.font-color: "#E8F0FA"
    style.font-size: 16
  }
  jif-container-clock: {
    style.fill: "#2A2214"
    style.stroke: "#F5B942"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-color: "#E8F0FA"
    style.font-size: 16
  }
  jif-container-converter: {
    style.fill: "#102B29"
    style.stroke: "#34D399"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-color: "#E8F0FA"
    style.font-size: 16
  }
  jif-container-fpga: {
    style.fill: "#0B2638"
    style.stroke: "#38BDF8"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-color: "#E8F0FA"
    style.font-size: 16
  }
  jif-title: {
    shape: text
    style.font-size: 22
    style.font-color: "#E8F0FA"
    style.bold: true
  }
  jif-subtitle: {
    shape: text
    style.font-size: 13
    style.font-color: "#91A4BC"
  }
  jif-label: {
    shape: text
    style.font-size: 12
    style.font-color: "#CBD5E1"
    style.bold: true
  }
  jif-badge: {
    style.fill: "#16283D"
    style.stroke: "#38516D"
    style.stroke-width: 1
    style.border-radius: 20
    style.font-color: "#E8F0FA"
    style.font-size: 11
  }

  # ── Semantic connection styles ──
  jif-signal: {
    style.stroke: "#91A4BC"
    style.stroke-width: 2
    style.font-color: "#CBD5E1"
    style.font-size: 12
  }
  jif-signal-reference: {
    style.stroke: "#A78BFA"
    style.stroke-width: 2
    style.font-color: "#C4B5FD"
    style.font-size: 12
  }
  jif-signal-clock: {
    style.stroke: "#F5B942"
    style.stroke-width: 2
    style.font-color: "#FCD34D"
    style.font-size: 12
  }
  jif-signal-sysref: {
    style.stroke: "#E879F9"
    style.stroke-width: 2
    style.stroke-dash: 6
    style.font-color: "#F0ABFC"
    style.font-size: 12
  }
  jif-signal-data: {
    style.stroke: "#38BDF8"
    style.stroke-width: 4
    style.font-color: "#7DD3FC"
    style.font-size: 12
  }
  jif-signal-feedback: {
    style.stroke: "#64748B"
    style.stroke-width: 1
    style.stroke-dash: 4
    style.font-color: "#91A4BC"
    style.font-size: 11
  }

  # ── Converter and JESD datapath ──
  adc: {
    icon: "data:image/svg+xml;base64,"
    style.fill: "#102B29"
    style.stroke: "#34D399"
    style.font-color: "#E8F0FA"
  }
  dac: {
    icon: "data:image/svg+xml;base64,"
    style.fill: "#102B29"
    style.stroke: "#34D399"
    style.font-color: "#E8F0FA"
  }
  ddc: {
    style.fill: "#102B29"
    style.stroke: "#34D399"
    style.font-color: "#E8F0FA"
    style.border-radius: 8
  }
  duc: {
    style.fill: "#102B29"
    style.stroke: "#34D399"
    style.font-color: "#E8F0FA"
    style.border-radius: 8
  }
  jesd204framer: {
    style.fill: "#08314A"
    style.stroke: "#38BDF8"
    style.font-color: "#E8F0FA"
    style.border-radius: 8
  }
  jesd204deframer: {
    style.fill: "#08314A"
    style.stroke: "#38BDF8"
    style.font-color: "#E8F0FA"
    style.border-radius: 8
  }
  framer: {
    style.fill: "#08314A"
    style.stroke: "#38BDF8"
    style.font-color: "#E8F0FA"
    style.border-radius: 8
  }
  deframer: {
    style.fill: "#08314A"
    style.stroke: "#38BDF8"
    style.font-color: "#E8F0FA"
    style.border-radius: 8
  }
  crossbar: {
    icon: "data:image/svg+xml;base64,"
    style.fill: "#2A2214"
    style.stroke: "#F5B942"
    style.font-color: "#E8F0FA"
  }
  mux: {
    icon: "data:image/svg+xml;base64,"
    style.fill: "#2A2214"
    style.stroke: "#F5B942"
    style.font-color: "#E8F0FA"
  }

  # ── Reference and generic structural blocks ──
  input: {
    style.fill: "#211B3E"
    style.stroke: "#A78BFA"
    style.font-color: "#E8F0FA"
  }
  out_clock_connected: {
    style.fill: "#211B3E"
    style.stroke: "#A78BFA"
    style.font-color: "#E8F0FA"
  }
  shell: {
    style.fill: "#101F33"
    style.stroke: "#41536B"
    style.font-color: "#E8F0FA"
    style.border-radius: 10
  }

  # ── Clock and PLL blocks ──
  divider: {
    style.fill: "#2A2214"
    style.stroke: "#F5B942"
    style.font-color: "#E8F0FA"
  }
  cpll: {
    style.fill: "#2A2214"
    style.stroke: "#F5B942"
    style.font-color: "#E8F0FA"
    style.border-radius: 10
  }
  qpll: {
    style.fill: "#2A2214"
    style.stroke: "#F5B942"
    style.font-color: "#E8F0FA"
    style.border-radius: 10
  }
  phase-frequency-detector: {
    style.fill: "#2A2214"
    style.stroke: "#F5B942"
    style.font-color: "#E8F0FA"
  }
  charge-pump: {
    style.fill: "#2A2214"
    style.stroke: "#F5B942"
    style.font-color: "#E8F0FA"
    style.border-radius: 8
  }
  loop-filter: {
    style.fill: "#2A2214"
    style.stroke: "#F5B942"
    style.font-color: "#E8F0FA"
    style.border-radius: 8
  }
  vco: {
    style.fill: "#2A2214"
    style.stroke: "#F5B942"
    style.font-color: "#E8F0FA"
  }
  voltage-controlled-oscillator: {
    style.fill: "#2A2214"
    style.stroke: "#F5B942"
    style.font-color: "#E8F0FA"
  }

  # ── FPGA and transceiver blocks ──
  ip: {
    style.fill: "#0B2638"
    style.stroke: "#38BDF8"
    style.font-color: "#E8F0FA"
    style.border-radius: 8
  }
  phy: {
    style.fill: "#0B2638"
    style.stroke: "#38BDF8"
    style.font-color: "#E8F0FA"
    style.border-radius: 10
  }
  transceiver: {
    style.fill: "#0B2638"
    style.stroke: "#38BDF8"
    style.font-color: "#E8F0FA"
    style.border-radius: 8
  }
  serdes: {
    style.fill: "#0B2638"
    style.stroke: "#38BDF8"
    style.font-color: "#E8F0FA"
    style.border-radius: 8
  }
  decoder: {
    style.fill: "#0B2638"
    style.stroke: "#38BDF8"
    style.font-color: "#E8F0FA"
    style.border-radius: 8
  }
  trx-dividers: {
    style.fill: "#101F33"
    style.stroke: "#41536B"
    style.font-color: "#E8F0FA"
    style.border-radius: 10
  }
  cdr: {
    style.fill: "#0B2638"
    style.stroke: "#38BDF8"
    style.font-color: "#E8F0FA"
    style.border-radius: 8
  }
}
