  sw-config: {
    style.fill: "#FFF3E0"
    style.stroke: "#F5A623"
    style.border-radius: 8
    style.shadow: true
    style.font-color: "#231F20"
  }

  # ── AI/ML & Agent Workflow ──
  sw-model: {
    style.fill: "#D6EAF8"
    style.stroke: "#0067B9"
    style.border-radius: 8
    style.shadow: true
    style.font-color: "#231F20"
