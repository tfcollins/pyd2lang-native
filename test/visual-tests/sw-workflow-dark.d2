# SW component classes — styled shapes with type-specific colors
# Color coding: blue=compute, green=output/eval, amber=config/data, grey=tools, dark=terminal

classes: {
  # ── Core Software / Infrastructure ──
  sw-server: {
    style.fill: "#E3F2FD"
    style.stroke: "#0067B9"
    style.border-radius: 8
    style.shadow: true
    style.font-color: "#231F20"
  }
  sw-database: {
    shape: cylinder
    style.fill: "#E8EAF6"
    style.stroke: "#004A87"
    style.font-color: "#231F20"
  }
  sw-queue: {
    style.fill: "#E3F2FD"
    style.stroke: "#0067B9"
    style.border-radius: 8
    style.shadow: true
    style.font-color: "#231F20"
  }
  sw-api: {
    style.fill: "#E3F2FD"
    style.stroke: "#0067B9"
    style.border-radius: 8
    style.shadow: true
    style.font-color: "#231F20"
  }
  sw-cloud: {
    shape: cloud
    style.fill: "#E3F2FD"
    style.stroke: "#4D9AD5"
    style.font-color: "#231F20"
  }
  sw-container-svc: {
    style.fill: "#E3F2FD"
    style.stroke: "#0067B9"
    style.border-radius: 8
    style.shadow: true
    style.font-color: "#231F20"
  }
  sw-function: {
    style.fill: "#E8F5E9"
    style.stroke: "#007A33"
    style.border-radius: 8
    style.shadow: true
    style.font-color: "#231F20"
  }
  sw-cache: {
    style.fill: "#FFF3E0"
    style.stroke: "#F5A623"
    style.border-radius: 8
    style.shadow: true
    style.font-color: "#231F20"
  }
  sw-storage: {
    shape: cylinder
    style.fill: "#E8EAF6"
    style.stroke: "#004A87"
    style.font-color: "#231F20"
  }
  sw-gateway: {
    shape: hexagon
    style.fill: "#E3F2FD"
    style.stroke: "#004A87"
    style.font-color: "#231F20"
  }
  sw-browser: {
    style.fill: "#E3F2FD"
    style.stroke: "#4D9AD5"
    style.border-radius: 8
    style.shadow: true
    style.font-color: "#231F20"
  }
  sw-mobile: {
    style.fill: "#E3F2FD"
